# MiniMax (LLM) — get key from https://api.minimax.io dashboard
LLM_API_KEY=your-minimax-key-here
LLM_BASE_URL=https://api.minimax.io/v1
LLM_MODEL=MiniMax-Text-01

# Google Maps — get keys from Google Cloud Console
# Browser key: HTTP-referrer-restricted in Phase 7
# Server key: IP-restricted in Phase 7
MAPS_BROWSER_KEY=your-browser-key-here
MAPS_SERVER_KEY=your-server-key-here

# App config
APP_ENV=development
LOG_LEVEL=INFO
MAX_LLM_CALLS_PER_DAY=100

# Phase 7 — Sentry
SENTRY_DSN=

# Render provides PORT in production
PORT=8000